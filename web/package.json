    "next": "^16.2.1",
    "next-seo": "^6",
    "postcss": "^8.4.5",
    "prop-types": "^15.7.2",
    "react": "^19",
    "react-dom": "^19",
    "react-portal": "^4.2.1",
    "tailwindcss": "^4.2.2",
    "zustand": "^5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.14",
    "jsdom": "^29.0.1",
